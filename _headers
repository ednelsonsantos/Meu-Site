# Cloudflare Pages - Headers de Cache

# Assets estáticos do WordPress (CSS, JS, imagens, fontes)
/wp-content/*
  Cache-Control: public, max-age=31536000, immutable

/wp-includes/*
  Cache-Control: public, max-age=31536000, immutable

# Páginas HTML - cache curto para permitir atualizações
/*.html
  Cache-Control: public, max-age=3600

# Raiz e páginas (sem extensão)
/
  Cache-Control: public, max-age=3600
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
