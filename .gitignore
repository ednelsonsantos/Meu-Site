# Pasta de build gerada pelo Cloudflare (nunca versionar)
dist/

# Cache do WordPress (arquivos gerados dinamicamente)
wp-content/cache/
wp-content/uploads/cache/

# Logs
*.log
error_log

# Sistema operacional
.DS_Store
Thumbs.db
desktop.ini

# Editores
.vscode/
.idea/
*.swp
*.swo

# Node (caso instale dependências locais)
node_modules/
package-lock.json

# Scripts e ferramentas locais (não vão para produção)
*.py
*.sh
novo-post.html
templates/

# Claude Code (configurações locais da IA)
.claude/

# Arquivos pesados (limite Cloudflare Pages: 25MB por arquivo)
*.pdf
audios/*.wav
audios/*.flac
